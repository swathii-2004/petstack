# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DB_NAME=petstack

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme_use_a_long_random_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@petstack.com

# ─── Frontend Origins ─────────────────────────────────────────────────────────
FRONTEND_USER_URL=http://localhost:3000
FRONTEND_VET_URL=http://localhost:3001
FRONTEND_SELLER_URL=http://localhost:3002
FRONTEND_ADMIN_URL=http://localhost:3003
